<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>Invoice</title>
  </head>
  <body
    style="margin:0;padding:0;background:#f6f8fb;font-family:Arial,Helvetica,sans-serif;color:#111;"
  >
    <div style="max-width:720px;margin:24px auto;padding:16px;">
      <div
        style="background:#ffffff;border-radius:14px;box-shadow:0 6px 24px rgba(0,0,0,.06);overflow:hidden;"
      >
        <div
          style="padding:22px 24px;background:linear-gradient(135deg,#0ea5e9,#6366f1);color:#fff;"
        >
          <div style="font-size:22px;font-weight:700;">Invoice</div>
          <div
            style="margin-top:6px;font-size:13px;opacity:.95;"
          >{{companyName}}</div>
        </div>

        <div style="padding:22px 24px;">
          <p style="margin:0 0 10px 0;font-size:14px;line-height:1.5;">Hi
            {{clientName}},</p>

          <p
            style="margin:0 0 14px 0;font-size:14px;line-height:1.6;color:#374151;"
          >
            Berikut terlampir invoice
            <strong>{{invoiceNumber}}</strong>
            dari
            <strong>{{companyName}}</strong>.
          </p>

          <div style="display:flex;gap:12px;flex-wrap:wrap;margin:18px 0;">
            <div
              style="flex:1;min-width:220px;border:1px solid #e5e7eb;border-radius:12px;padding:14px;"
            >
              <div
                style="font-size:12px;color:#6b7280;margin-bottom:6px;"
              >Informasi Penerima</div>
              <div
                style="font-size:14px;font-weight:700;color:#111827;"
              >{{clientName}}</div>
              <div
                style="font-size:13px;color:#374151;margin-top:4px;"
              >{{clientEmail}}</div>
              {{#if clientAddress}}
                <div
                  style="font-size:13px;color:#374151;margin-top:6px;white-space:pre-line;"
                >{{clientAddress}}</div>
              {{/if}}
            </div>

            <div
              style="flex:1;min-width:220px;border:1px solid #e5e7eb;border-radius:12px;padding:14px;"
            >
              <div
                style="font-size:12px;color:#6b7280;margin-bottom:6px;"
              >Detail Invoice</div>
              <div style="font-size:13px;color:#374151;"><strong>Issue Date:</strong>
                {{issueDate}}</div>
              <div style="font-size:13px;color:#374151;margin-top:4px;"><strong
                >Due Date:</strong>
                {{dueDate}}</div>
              <div style="font-size:13px;color:#374151;margin-top:4px;"><strong
                >Currency:</strong>
                {{currency}}</div>
            </div>
          </div>

          <div
            style="border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;"
          >
            <div
              style="background:#f3f4f6;padding:10px 12px;font-size:12px;font-weight:700;color:#111827;"
            >
              Items
            </div>

            <table style="width:100%;border-collapse:collapse;">
              <thead>
                <tr style="background:#fafafa;">
                  <th
                    style="text-align:left;padding:10px 12px;font-size:12px;color:#6b7280;border-top:1px solid #e5e7eb;"
                  >Item</th>
                  <th
                    style="text-align:right;padding:10px 12px;font-size:12px;color:#6b7280;border-top:1px solid #e5e7eb;"
                  >Qty</th>
                  <th
                    style="text-align:right;padding:10px 12px;font-size:12px;color:#6b7280;border-top:1px solid #e5e7eb;"
                  >Price</th>
                  <th
                    style="text-align:right;padding:10px 12px;font-size:12px;color:#6b7280;border-top:1px solid #e5e7eb;"
                  >Total</th>
                </tr>
              </thead>
              <tbody>
                {{#each items}}
                  <tr>
                    <td style="padding:10px 12px;border-top:1px solid #f1f5f9;">
                      <div
                        style="font-size:13px;font-weight:700;color:#111827;"
                      >{{name}}</div>
                      {{#if description}}
                        <div
                          style="font-size:12px;color:#6b7280;margin-top:3px;"
                        >{{description}}</div>
                      {{/if}}
                    </td>
                    <td
                      style="padding:10px 12px;border-top:1px solid #f1f5f9;text-align:right;font-size:13px;color:#111827;"
                    >{{qty}}</td>
                    <td
                      style="padding:10px 12px;border-top:1px solid #f1f5f9;text-align:right;font-size:13px;color:#111827;"
                    >{{price}}</td>
                    <td
                      style="padding:10px 12px;border-top:1px solid #f1f5f9;text-align:right;font-size:13px;font-weight:700;color:#111827;"
                    >{{lineTotal}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>

          <div style="margin-top:14px;display:flex;justify-content:flex-end;">
            <div
              style="width:320px;border:1px solid #e5e7eb;border-radius:12px;padding:12px 14px;"
            >
              <div
                style="display:flex;justify-content:space-between;font-size:13px;color:#374151;"
              >
                <span>Subtotal</span>
                <span>{{subtotal}}</span>
              </div>
              <div
                style="display:flex;justify-content:space-between;font-size:13px;color:#374151;margin-top:6px;"
              >
                <span>Tax</span>
                <span>{{taxAmount}}</span>
              </div>
              <div
                style="display:flex;justify-content:space-between;font-size:13px;color:#374151;margin-top:6px;"
              >
                <span>Discount</span>
                <span>{{discountAmount}}</span>
              </div>
              <div style="height:1px;background:#e5e7eb;margin:10px 0;"></div>
              <div
                style="display:flex;justify-content:space-between;font-size:14px;font-weight:800;color:#111827;"
              >
                <span>Total</span>
                <span>{{total}}</span>
              </div>
            </div>
          </div>

          {{#if notes}}
            <div
              style="margin-top:16px;padding:12px 14px;border:1px solid #e5e7eb;border-radius:12px;background:#fafafa;"
            >
              <div
                style="font-size:12px;color:#6b7280;font-weight:700;margin-bottom:6px;"
              >Notes</div>
              <div
                style="font-size:13px;color:#111827;white-space:pre-line;"
              >{{notes}}</div>
            </div>
          {{/if}}

          <div style="margin-top:18px;font-size:12px;color:#6b7280;">
            Email ini dikirim melalui Invoice App.
          </div>
        </div>
      </div>
    </div>
  </body>
</html>